# Copy this file to .env and edit the values for your machine.
# .env is gitignored — never commit secrets or local paths.

# URL of your running ComfyUI server.
COMFYUI_URL=http://127.0.0.1:8188

# Folder ComfyUI scans for LoadImage inputs.
# Default ComfyUI portable: <portable>/ComfyUI/input
# Example (Windows): D:/ComfyUI/ComfyUI_windows_portable/ComfyUI/input
# Example (Linux):   /home/you/ComfyUI/input
COMFYUI_INPUT_DIR=

# Folder ComfyUI writes generated images to.
# If you launched ComfyUI with --output-directory, use that path.
# Default ComfyUI portable: <portable>/ComfyUI/output
COMFYUI_OUTPUT_DIR=

# Seconds to wait for a single image generation before giving up.
COMFYUI_TIMEOUT=300

# Model filenames as they appear inside ComfyUI/models/. Override these if
# you use different FLUX.2 variants (e.g. a different quantization, or 4B).
FLUX2_MODEL_FILE=flux-2-klein-9b-Q4_K_S.gguf
FLUX2_CLIP_FILE=qwen_3_8b_fp8mixed.safetensors
FLUX2_VAE_FILE=flux2-vae.safetensors

# Sampling steps. Klein is distilled to 4 steps — leave alone unless you
# swapped to a non-distilled model.
FLUX2_STEPS=4
